# KSK VASU & Co - Environment Variables Template

# MongoDB Connection
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Session Settings
SESSION_SECRET=your_long_session_secret_here

# Admin Login Credentials
ADMIN_USER=admin
ADMIN_PASS=adminpassword

# Admin Action Verification Password
ADMIN_ACTION_PASSWORD=123456789

# Server Port
PORT=5500

# SMTP Configuration for OTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-business-email@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL=admin-receiver@gmail.com
