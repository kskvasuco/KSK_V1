{
  "expo": {
    "name": "KSK VASU & Co",
    "slug": "ksk-vasu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android/adaptive-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nithindev.kskvasushop",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/song1.wav",
            "./assets/sounds/song2.wav",
            "./assets/sounds/song3.wav",
            "./assets/sounds/song4.wav",
            "./assets/sounds/song5.wav"
          ]
        }
      ]
    ]
  }
}
